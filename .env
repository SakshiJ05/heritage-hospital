# Local configuration. THIS FILE IS GITIGNORED — never commit it.
# See .env.example for what every variable does.

PORT=5000

# The one bootstrap account. `npm run seed` creates it; everything else — PRO,
# agents, lab, patients, orders — is created through the product.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Heritage@2026
ADMIN_NAME=Administrator

# MongoDB Atlas. The database name (heritage_diagnostics) matters: without it,
# Mongo silently writes everything into a database called "test".
MONGODB_URI=mongodb+srv://sakshigupta9029_db_user:xpdAV0GiIHidSdj4@cluster0.9hwcmgd.mongodb.net/heritage_diagnostics?retryWrites=true&w=majority&appName=Cluster0

# This machine's DNS refuses SRV lookups, which mongodb+srv:// needs — without
# this the driver fails with a misleading "querySrv ECONNREFUSED". Unset it on a
# server whose DNS works normally.
DNS_SERVERS=8.8.8.8,1.1.1.1

JWT_SECRET=heritage-local-dev-secret-please-change-in-production
JWT_EXPIRES_IN=7d

# Every OTP is this code, and it is echoed back to the app so testing is one tap.
# REMOVE THIS LINE IN PRODUCTION — with it set, anyone can log in as any number.
DEV_OTP=1234

UPLOAD_DIR=./uploads

# Dashboard origin (Vite dev server).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
