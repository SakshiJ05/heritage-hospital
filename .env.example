# --- core -------------------------------------------------------------------
PORT=5000

# Local mongod:
#   MONGODB_URI=mongodb://127.0.0.1:27017/heritage_diagnostics
# MongoDB Atlas — ALWAYS put the database name after the host, or Mongo silently
# writes everything into a database called "test":
#   MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxx.mongodb.net/heritage_diagnostics?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/heritage_diagnostics

# Only needed if your DNS refuses SRV lookups, which mongodb+srv:// requires.
# The symptom is a misleading "querySrv ECONNREFUSED" that looks like Atlas is
# down. Leave unset on a server whose DNS works normally.
# DNS_SERVERS=8.8.8.8,1.1.1.1

# Required. Must be at least 16 characters; the server refuses to boot without it.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# --- OTP --------------------------------------------------------------------
# When set, every OTP is this fixed code and it is echoed in the send-otp response
# (outside production only). LEAVE THIS UNSET IN PRODUCTION — with it set, anyone
# can log in as any phone number.
DEV_OTP=1234

# --- uploads ----------------------------------------------------------------
UPLOAD_DIR=./uploads

# --- SMS (MSG91). Unset -> OTPs and alerts are logged to the console instead. --
SMS_API_KEY=
SMS_SENDER_ID=
SMS_TEMPLATE_ID=

# --- push (Expo). Unset -> push is logged instead. ----------------------------
EXPO_ACCESS_TOKEN=

# --- email (report delivery). Unset -> logged instead. ------------------------
SMTP_URL=
SMTP_FROM=Heritage Diagnostics <no-reply@heritage.example>

# --- web admin dashboard origin ----------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173
